source "https://rubygems.org"

# Using the github-pages gem (rather than a bare "jekyll" gem) keeps your
# local build's plugin versions identical to what GitHub's own servers use,
# so if it builds for you locally, it'll build the same way on GitHub Pages.
gem "github-pages", group: :jekyll_plugins

gem "jekyll-include-cache"

# Only needed if you want to run `bundle exec jekyll serve` locally.
# If you'd rather skip installing Ruby entirely and just let GitHub build
# the site on every push, you can ignore this file and delete it — GitHub
# Pages doesn't require you to have Ruby installed on your own machine.
